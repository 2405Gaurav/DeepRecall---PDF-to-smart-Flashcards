# Neon PostgreSQL — use the pooled connection string for DATABASE_URL (serverless-friendly).
# In Neon: Dashboard → Connection details → copy "Pooled" URI for Prisma.
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# Prisma migrations (Neon recommends a direct non-pooled URL for migrations)
DIRECT_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override default model (default is gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
